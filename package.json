{
  "name": "operativo-pancita",
  "description": "Mapa y tablero compartido para buscar a Pancita, también llamada Panza o Pancite.",
  "private": true,
  "version": "0.2.0",
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "pancita",
    "pancite",
    "panza",
    "perro perdido",
    "busqueda canina",
    "missing dog",
    "animal search and rescue"
  ],
  "type": "module",
  "packageManager": "yarn@1.22.19",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:rules": "firebase emulators:exec --only firestore \"vitest run --config vitest.rules.config.ts\"",
    "emulators": "firebase emulators:start --import=./seed/emulator-data --export-on-exit=./seed/emulator-data",
    "seed": "node --import tsx seed/seed-demo.ts"
  },
  "dependencies": {
    "firebase": "^11.10.0",
    "idb-keyval": "^6.2.2",
    "leaflet": "^1.9.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.60.0",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.7.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@firebase/rules-unit-testing": "^4.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/leaflet": "^1.9.20",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9.31.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "firebase-tools": "^14.11.0",
    "globals": "^16.3.0",
    "jsdom": "^26.1.0",
    "tsx": "^4.20.3",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.37.0",
    "vite": "^7.0.5",
    "vite-plugin-pwa": "^1.0.1",
    "vitest": "^3.2.4"
  }
}
