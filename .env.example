VITE_FIREBASE_API_KEY=demo-api-key
VITE_FIREBASE_AUTH_DOMAIN=demo-pancite.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=demo-pancite
VITE_FIREBASE_STORAGE_BUCKET=demo-pancite.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef
VITE_FIREBASE_MEASUREMENT_ID=
# Use emulators for local Milestone 1 development
VITE_USE_EMULATORS=true
# Owner bootstrap email (must match a signed-in Google account in production)
VITE_OWNER_BOOTSTRAP_EMAIL=owner@example.com
# Public case slug for this deployment
VITE_CASE_SLUG=pancite
# Optional: callable function URL override when not using emulators
# VITE_PUBLIC_REPORT_URL=
