rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ponytail: no Firebase Auth — family MVP gate is client-side username login.
    // Ceiling: anyone with the app URL can write. Upgrade: enable Auth + tighten.

    match /publicCases/{slug} {
      allow read: if true;
      allow write: if true;
    }

    match /cases/{caseId} {
      allow read, write: if true;

      match /{subcollection}/{docId} {
        allow read, write: if true;
      }
    }
  }
}
