rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function memberPath(caseId) {
      return /databases/$(database)/documents/cases/$(caseId)/members/$(request.auth.uid);
    }

    function memberDoc(caseId) {
      return get(memberPath(caseId));
    }

    function isActiveMember(caseId) {
      return signedIn()
        && exists(memberPath(caseId))
        && memberDoc(caseId).data.active == true;
    }

    function memberRole(caseId) {
      return memberDoc(caseId).data.role;
    }

    function isOwner(caseId) {
      return isActiveMember(caseId) && memberRole(caseId) == 'owner';
    }

    function isCoordinatorOrOwner(caseId) {
      return isActiveMember(caseId)
        && memberRole(caseId) in ['owner', 'coordinator'];
    }

    // Sanitized public projection only
    match /publicCases/{slug} {
      allow read: if true;
      allow write: if false; // owner/coordinator publication via Admin SDK / trusted function
    }

    match /cases/{caseId} {
      allow read: if isActiveMember(caseId);
      allow create, update: if isOwner(caseId);
      allow delete: if false;

      match /members/{uid} {
        allow read: if isActiveMember(caseId);
        allow create, update: if isOwner(caseId);
        allow delete: if isOwner(caseId) && uid != request.auth.uid;
      }

      // Invitations contain private emails and are only handled by trusted functions.
      match /invites/{inviteId} {
        allow read, write: if false;
      }

      match /leads/{leadId} {
        allow read: if isActiveMember(caseId);
        allow create: if isActiveMember(caseId);
        allow update: if isCoordinatorOrOwner(caseId)
          || (isActiveMember(caseId)
              && resource.data.capturedByUid == request.auth.uid
              && resource.data.status == 'new');
        allow delete: if false;
      }

      match /sightings/{sightingId} {
        allow read: if isActiveMember(caseId);
        allow create, update: if isCoordinatorOrOwner(caseId);
        allow delete: if false;
      }

      match /audit/{eventId} {
        allow read: if isCoordinatorOrOwner(caseId);
        allow create: if isCoordinatorOrOwner(caseId);
        allow update, delete: if false;
      }

      match /signs/{signId} {
        allow read: if isActiveMember(caseId);
        allow create: if isActiveMember(caseId)
          && request.resource.data.createdByUid == request.auth.uid;
        allow update: if isActiveMember(caseId)
          && request.resource.data.createdByUid == resource.data.createdByUid;
        allow delete: if isCoordinatorOrOwner(caseId);
      }


      match /tasks/{taskId} {
        allow read: if isActiveMember(caseId);
        allow create: if isActiveMember(caseId)
          && request.resource.data.createdByUid == request.auth.uid
          && request.resource.data.status == 'open';
        allow update: if isActiveMember(caseId)
          && request.resource.data.createdByUid == resource.data.createdByUid;
        allow delete: if false;
      }

      match /coverage/{cellId} {
        allow read: if isActiveMember(caseId);
        allow write: if isActiveMember(caseId);
      }

      match /outings/{outingId} {
        allow read: if isActiveMember(caseId);
        allow write: if isActiveMember(caseId);
      }

      match /avoidAreas/{areaId} {
        allow read: if isActiveMember(caseId);
        allow write: if isCoordinatorOrOwner(caseId);
      }

      match /zones/{zoneId} {
        allow read: if isActiveMember(caseId);
        allow create, update: if isCoordinatorOrOwner(caseId)
          && request.resource.data.updatedByUid == request.auth.uid;
        allow delete: if false;
      }

      match /liveLocations/{uid} {
        allow read: if isActiveMember(caseId);
        allow write: if isActiveMember(caseId) && uid == request.auth.uid;
      }
    }
  }
}
