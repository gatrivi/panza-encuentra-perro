rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function memberPath(caseId) {
      return /databases/$(database)/documents/cases/$(caseId)/members/$(request.auth.uid);
    }

    function memberDoc(caseId) {
      return get(memberPath(caseId));
    }

    function isActiveMember(caseId) {
      return signedIn()
        && exists(memberPath(caseId))
        && memberDoc(caseId).data.active == true;
    }

    function memberRole(caseId) {
      return memberDoc(caseId).data.role;
    }

    function isOwner(caseId) {
      return isActiveMember(caseId) && memberRole(caseId) == 'owner';
    }

    function isCoordinatorOrOwner(caseId) {
      return isActiveMember(caseId)
        && memberRole(caseId) in ['owner', 'coordinator'];
    }

    // Sanitized public projection — signed-in may bootstrap first case (no Blaze/CF)
    match /publicCases/{slug} {
      allow read: if true;
      allow create: if signedIn()
        && slug in ['pancita', 'pancite']
        && request.resource.data.keys().hasAll(['caseId', 'status', 'animal', 'updatedAt'])
        && request.resource.data.status == 'active';
      allow update, delete: if false;
    }

    match /cases/{caseId} {
      allow read: if isActiveMember(caseId);
      allow create: if signedIn()
        && request.resource.data.keys().hasAll(['slug', 'status', 'animal', 'mapCenter', 'createdAt', 'updatedAt'])
        && request.resource.data.status == 'active'
        && request.resource.data.slug in ['pancita', 'pancite'];
      allow update: if isOwner(caseId);
      allow delete: if false;

      // First writer wins owner; others join as coordinator (ponytail: no CF)
      match /locks/{lockId} {
        allow read: if signedIn();
        allow create: if signedIn()
          && lockId == 'owner'
          && request.resource.data.uid == request.auth.uid;
        allow update, delete: if false;
      }

      match /members/{uid} {
        allow read: if isActiveMember(caseId)
          || (signedIn() && request.auth.uid == uid);
        allow create: if signedIn()
          && request.auth.uid == uid
          && request.resource.data.active == true
          && request.resource.data.email == request.auth.token.email
          && request.resource.data.role in ['owner', 'coordinator']
          && (
            request.resource.data.role == 'coordinator'
            || (
              request.resource.data.role == 'owner'
              && exists(/databases/$(database)/documents/cases/$(caseId)/locks/owner)
              && get(/databases/$(database)/documents/cases/$(caseId)/locks/owner).data.uid
                == request.auth.uid
            )
          );
        allow update: if isOwner(caseId)
          || (signedIn()
              && request.auth.uid == uid
              && request.resource.data.role == resource.data.role
              && request.resource.data.email == resource.data.email);
        allow delete: if isOwner(caseId) && uid != request.auth.uid;
      }

      match /leads/{leadId} {
        allow read: if isActiveMember(caseId);
        // Members + anonymous public_form (replaces submitPublicReport CF)
        allow create: if isActiveMember(caseId)
          || (
            request.resource.data.origin == 'public_form'
            && request.resource.data.status == 'new'
            && request.resource.data.priority in ['high', 'normal']
            && request.resource.data.keys().hasAll([
              'origin', 'rawText', 'attachmentPaths', 'capturedAt',
              'reporter', 'parserSuggestions', 'status', 'priority'
            ])
          );
        allow update: if isCoordinatorOrOwner(caseId)
          || (isActiveMember(caseId)
              && resource.data.capturedByUid == request.auth.uid
              && resource.data.status == 'new');
        allow delete: if false;
      }

      match /sightings/{sightingId} {
        allow read: if isActiveMember(caseId);
        allow create, update: if isCoordinatorOrOwner(caseId);
        allow delete: if false;
      }

      match /audit/{eventId} {
        allow read: if isCoordinatorOrOwner(caseId);
        allow create: if isCoordinatorOrOwner(caseId);
        allow update, delete: if false;
      }

      match /signs/{signId} {
        allow read: if isActiveMember(caseId);
        allow create, update: if isActiveMember(caseId);
        allow delete: if isCoordinatorOrOwner(caseId);
      }

      match /coverage/{cellId} {
        allow read: if isActiveMember(caseId);
        allow write: if isActiveMember(caseId);
      }

      match /outings/{outingId} {
        allow read: if isActiveMember(caseId);
        allow write: if isActiveMember(caseId);
      }

      match /avoidAreas/{areaId} {
        allow read: if isActiveMember(caseId);
        allow write: if isCoordinatorOrOwner(caseId);
      }

      match /zones/{zoneId} {
        allow read: if isActiveMember(caseId);
        allow write: if isCoordinatorOrOwner(caseId);
      }

      match /liveLocations/{uid} {
        allow read: if isActiveMember(caseId);
        allow write: if isActiveMember(caseId) && uid == request.auth.uid;
      }
    }
  }
}
